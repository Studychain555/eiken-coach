# EigoMaster 環境変数テンプレート
# .env.local にコピーして実際の値を設定してください

# ============================================================================
# Supabase 設定（公開キー）
# ============================================================================
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# Supabase 設定（秘密鍵 - サーバーサイドのみ）
# ============================================================================
# WARNING: サーバーサイドのみで使用、クライアントに送信しないこと
SUPABASE_SERVICE_ROLE_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# Claude API キー
# ============================================================================
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-api03-xxxxx...

# ============================================================================
# Whisper API キー（音声認識 - オプション）
# ============================================================================
EXPO_PUBLIC_WHISPER_API_KEY=

# ============================================================================
# 暗号化設定
# ============================================================================
# データ暗号化用の秘密鍵（AES-256-GCM）
# 本番環境では環境変数から読み込むこと
EXPO_PUBLIC_ENCRYPTION_KEY=your-32-character-encryption-key

# ============================================================================
# API 設定
# ============================================================================
# API ベースURL
EXPO_PUBLIC_API_URL=https://api.eigomaster.jp

# API タイムアウト（ミリ秒）
EXPO_PUBLIC_API_TIMEOUT_MS=30000

# ============================================================================
# JWT 設定
# ============================================================================
# JWT 署名用の秘密鍵（サーバーサイドのみ）
JWT_SECRET=your-jwt-secret-key-change-in-production

# JWT 有効期限
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================================
# セッション設定
# ============================================================================
# セッションタイムアウト（ミリ秒）
SESSION_TIMEOUT_MS=1800000

# ============================================================================
# レート制限設定
# ============================================================================
# ログイン試行の制限（回数/分）
AUTH_RATE_LIMIT=5

# API リクエストの制限（回数/分）
API_RATE_LIMIT=100

# ============================================================================
# デバッグ・ログ設定
# ============================================================================
# デバッグモード（true/false）
DEBUG=false

# ログレベル（error, warn, info, debug）
LOG_LEVEL=info

# ============================================================================
# 本番環境設定
# ============================================================================
# 環境（development, staging, production）
NODE_ENV=development

# アプリバージョン
APP_VERSION=1.0.0

# ============================================================================
# セキュリティ設定
# ============================================================================
# CORS 許可オリジン（カンマ区切り）
ALLOWED_ORIGINS=http://localhost:3000,https://eigomaster.jp

# HTTPS 強制（true/false）
ENFORCE_HTTPS=true

# ============================================================================
# 注意事項
# ============================================================================
# 1. このファイルは .gitignore に含まれています
# 2. .env.local ファイルを作成して実際の値を設定してください
# 3. 秘密鍵は絶対に Git にコミットしないこと
# 4. 本番環境では環境変数として設定する必要があります
# 5. 定期的にキーをローテーションしてください
