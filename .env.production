# EigoMaster 本番環境設定 - USE GitHub Actions SECRETS INSTEAD
# 更新日: 2026-03-19

# ========== Supabase 本番環境 ==========
# Set these in GitHub Actions secrets, not in this file
EXPO_PUBLIC_SUPABASE_URL=${EXPO_PUBLIC_SUPABASE_URL}
EXPO_PUBLIC_SUPABASE_ANON_KEY=${EXPO_PUBLIC_SUPABASE_ANON_KEY}
SUPABASE_SERVICE_ROLE_SECRET=${SUPABASE_SERVICE_ROLE_SECRET}

# ========== Claude API キー ==========
EXPO_PUBLIC_CLAUDE_API_KEY=${EXPO_PUBLIC_CLAUDE_API_KEY}

# ========== Whisper API（音声認識） ==========
EXPO_PUBLIC_WHISPER_API_KEY=${EXPO_PUBLIC_WHISPER_API_KEY}

# ========== Sentry エラーログ ==========
SENTRY_AUTH_TOKEN=${SENTRY_AUTH_TOKEN}
EXPO_PUBLIC_SENTRY_DSN=${EXPO_PUBLIC_SENTRY_DSN}

# ========== アナリティクス ==========
EXPO_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ========== 環境フラグ ==========
NODE_ENV=production
EXPO_PUBLIC_ENV=production
EXPO_PUBLIC_DEBUG_MODE=false

# ========== ビルド設定 ==========
EAS_BUILD_PLATFORM=ios
EAS_BUILD_PROFILE=production
